# Classifier backend configuration. Copy to `.env.local` (gitignored) and
# fill in, OR export these in your shell / set them as CI secrets.
# The crawler picks the first configured backend; with none, it runs
# heuristics-only (categories from sources.yaml, no summaries).

# ── Azure AI Foundry (OpenAI-compatible endpoint) — preferred ────────
# The `/openai/v1` base URL of your Foundry resource:
AZURE_FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com/openai/v1
AZURE_FOUNDRY_API_KEY=
# Deployment name to call (default: gpt-5.4-nano):
# OBSERVATORY_MODEL=gpt-5.4-nano

# ── Anthropic on Foundry (a Claude deployment) — alternative ─────────
# ANTHROPIC_FOUNDRY_API_KEY=
# ANTHROPIC_FOUNDRY_RESOURCE=<resource-name>        # or the full URL below
# ANTHROPIC_FOUNDRY_BASE_URL=https://<resource>.services.ai.azure.com/anthropic/
# OBSERVATORY_MODEL=claude-opus-4-8

# ── First-party Anthropic API — fallback ────────────────────────────
# ANTHROPIC_API_KEY=
